# === CMS runtime / secrets — nikad na GitHub ===
data/users.json
data/attempts.json

# === uploads/ — korisnički sadržaj, ne prati se u gitu ===
# Izuzeci ispod: brend fajlovi koji su deo dizajna i .htaccess/index.html
uploads/*
!uploads/.htaccess
!uploads/index.html
!uploads/favicon.png
!uploads/seba-logo_2x.png
!uploads/seba-crashbar.png
!uploads/Seba-Crashbar-home-slider2.jpg

# === lokalni test/backup fajlovi ===
content.backup.json
content.json.bak-*
*.tmp
.DS_Store
Thumbs.db

# === lokalna Claude Code podešavanja ===
.claude/settings.local.json

# === content.json — živi sadržaj sajta, menja se na serveru kroz admin ===
# Sajt je live, prvi deploy je odavno gotov — content.json je OTKAČEN iz
# praćenja (git rm --cached) da ga budući git pull/deploy nikad ne pregazi
# Sebinim izmenama sa servera. Ako ikad zatreba da se resetuje početni
# sadržaj, to se radi ručno (upload preko File Manager-a), ne preko gita.
content.json
