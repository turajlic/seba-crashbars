*.tmp
.DS_Store
Thumbs.db

# === lokalna Claude Code podešavanja ===
.claude/settings.local.json

# ============================================================
# VAŽNO — content.json:
# Trenutno je NAMERNO UKLJUČEN u git (ne u listi iznad) da server
# pri prvom deployu dobije početni sadržaj sajta.
#
# ODMAH POSLE PRVOG DEPLOYA: dodaj ovde liniju
#   content.json
# da budući `git pull` na hostingu ne bi pregazio Sebin živi
# sadržaj (izmene kroz admin panel) verzijom iz repoa.
# ============================================================
